{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4",
  "default_agent": "coordinator",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "http://127.0.0.1:54321/mcp",
      "oauth": false,
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Default implementation agent",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "wt *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git branch*": "allow",
          "git fetch*": "allow",
          "git remote*": "allow",
          "git rev-parse*": "allow",
          "git merge-base*": "allow",
          "pnpm *": "allow",
          "git add *": "ask",
          "git commit *": "ask",
          "git push *": "deny",
          "git switch *": "ask",
          "git checkout *": "deny",
          "git worktree *": "deny",
          "git reset *": "deny",
          "git clean *": "deny",
          "rm *": "deny",
          "chmod *": "deny",
          "chown *": "deny"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "description": "Planning-only analysis agent",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git branch*": "allow",
          "git fetch*": "allow",
          "git remote*": "allow",
          "git rev-parse*": "allow",
          "git merge-base*": "allow"
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "question": "allow",
    "edit": "ask",
    "webfetch": "ask",
    "bash": {
      "*": "ask",
      "wt *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git fetch*": "allow",
      "git remote*": "allow",
      "git rev-parse*": "allow",
      "git merge-base*": "allow",
      "pnpm *": "allow",
      "git push *": "deny",
      "git checkout *": "deny",
      "git worktree *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "rm *": "deny",
      "chmod *": "deny",
      "chown *": "deny"
    },
    "skill": {
      "*": "ask",
      "backend": "allow",
      "testing": "allow",
      "mobile-frontend": "allow",
      "mobile-recording": "allow",
      "web-frontend": "allow",
      "ui-package": "allow",
      "core-package": "allow",
      "provider-integrations": "allow",
      "documentation": "allow",
      "brainstorming": "allow",
      "worktrunk": "allow",
      "explaining-code": "allow",
      "managing-context-window": "allow"
    }
  }
}
