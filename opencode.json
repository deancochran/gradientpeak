{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "{env:SUPABASE_MCP_URL}",
      "oauth": false,
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "pnpm *": "allow",
      "rm *": "deny",
      "chmod *": "deny",
      "chown *": "deny"
    },
    "skill": {
      "*": "ask",
      "backend": "allow",
      "testing": "allow",
      "mobile-frontend": "allow",
      "mobile-recording": "allow",
      "web-frontend": "allow",
      "ui-package": "allow",
      "core-package": "allow",
      "provider-integrations": "allow",
      "documentation": "allow",
      "brainstorming": "allow",
      "worktrunk": "allow",
      "explaining-code": "allow",
      "managing-context-window": "allow"
    }
  }
}
