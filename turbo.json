{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "BETTER_AUTH_SECRET",
    "DATABASE_URL",
    "NEXT_PRIVATE_SUPABASE_SECRET_KEY",
    "NEXT_PRIVATE_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "POSTGRES_URL",
    "SUPABASE_DB_URL",
    "SUPABASE_SERVICE_ROLE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".output/**",
        ".nitro/**",
        ".tanstack/**",
        "dist/**"
      ]
    },
    "check": {
      "outputs": []
    },
    "check-types": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:e2e": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:e2e:web": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "test:e2e:mobile": {
      "dependsOn": [],
      "outputs": [],
      "cache": false
    },
    "test:all": {
      "dependsOn": ["test", "test:e2e:web", "test:e2e:mobile"],
      "outputs": [],
      "cache": false
    }
  }
}
