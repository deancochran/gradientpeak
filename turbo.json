{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "check": {
      "outputs": []
    },
    "check-types": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:e2e:web": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "test:e2e:mobile": {
      "dependsOn": [],
      "outputs": [],
      "cache": false
    },
    "test:all": {
      "dependsOn": ["test", "test:e2e:web", "test:e2e:mobile"],
      "outputs": [],
      "cache": false
    }
  }
}
