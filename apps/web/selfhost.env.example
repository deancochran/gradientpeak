# Copy to apps/web/.env.selfhost and replace values.

NODE_ENV=production
PORT=3000

# Public app origin for web callbacks/links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PRIVATE_SUPABASE_SECRET_KEY=your_service_role_key

# Optional: explicit server-side app URL fallback.
APP_URL=http://localhost:3000
