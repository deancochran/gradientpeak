# Copy to apps/web/.env.selfhost and replace values.

NODE_ENV=production
PORT=3000

# Public app origin for web callbacks/links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PRIVATE_SUPABASE_SECRET_KEY=your_service_role_key

# Optional: explicit server-side app URL fallback.
APP_URL=http://localhost:3000

# Better Auth email delivery.
# Use Mailtrap SMTP in development/staging or replace with your real SMTP provider.
AUTH_EMAIL_MODE=smtp
AUTH_EMAIL_FROM="GradientPeak <no-reply@example.com>"
AUTH_EMAIL_REPLY_TO=support@example.com
AUTH_SMTP_HOST=sandbox.smtp.mailtrap.io
AUTH_SMTP_PORT=2525
AUTH_SMTP_USER=your_mailtrap_username
AUTH_SMTP_PASS=your_mailtrap_password
AUTH_SMTP_SECURE=false
