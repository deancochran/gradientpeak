{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@repo/core": ["../../packages/core/index.ts"],
      "@repo/api": ["../../packages/api/index.ts"],
      "@repo/api/*": ["../../packages/api/src/*"],
      "@repo/auth/client": ["../../packages/auth/src/client.ts"],
      "@repo/auth/client/*": ["../../packages/auth/src/client/*"],
      "@repo/auth/server": ["../../packages/auth/src/server.ts"],
      "@repo/auth/session": ["../../packages/auth/src/contracts/session.ts"],
      "@repo/auth/callbacks": ["../../packages/auth/src/contracts/callbacks.ts"],
      "@repo/auth/*": ["../../packages/auth/src/*"],
      "@repo/db": ["../../packages/db/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
