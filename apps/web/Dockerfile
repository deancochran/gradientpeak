FROM node:20-bookworm-slim AS builder

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

WORKDIR /app

COPY . .

ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
ARG NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder
ARG NEXT_PRIVATE_SUPABASE_SECRET_KEY=sb_secret_placeholder
ARG OAUTH_CALLBACK_BASE_URL=http://localhost:3000
ARG STRAVA_CLIENT_ID=dummy
ARG STRAVA_CLIENT_SECRET=dummy
ARG WAHOO_CLIENT_ID=dummy
ARG WAHOO_CLIENT_SECRET=dummy
ARG WAHOO_WEBHOOK_SECRET=dummy
ARG TRAININGPEAKS_CLIENT_ID=dummy
ARG TRAININGPEAKS_CLIENT_SECRET=dummy
ARG GARMIN_CLIENT_ID=dummy
ARG GARMIN_CLIENT_SECRET=dummy
ARG ZWIFT_CLIENT_ID=dummy
ARG ZWIFT_CLIENT_SECRET=dummy

ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=$NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
ENV NEXT_PRIVATE_SUPABASE_SECRET_KEY=$NEXT_PRIVATE_SUPABASE_SECRET_KEY
ENV OAUTH_CALLBACK_BASE_URL=$OAUTH_CALLBACK_BASE_URL
ENV STRAVA_CLIENT_ID=$STRAVA_CLIENT_ID
ENV STRAVA_CLIENT_SECRET=$STRAVA_CLIENT_SECRET
ENV WAHOO_CLIENT_ID=$WAHOO_CLIENT_ID
ENV WAHOO_CLIENT_SECRET=$WAHOO_CLIENT_SECRET
ENV WAHOO_WEBHOOK_SECRET=$WAHOO_WEBHOOK_SECRET
ENV TRAININGPEAKS_CLIENT_ID=$TRAININGPEAKS_CLIENT_ID
ENV TRAININGPEAKS_CLIENT_SECRET=$TRAININGPEAKS_CLIENT_SECRET
ENV GARMIN_CLIENT_ID=$GARMIN_CLIENT_ID
ENV GARMIN_CLIENT_SECRET=$GARMIN_CLIENT_SECRET
ENV ZWIFT_CLIENT_ID=$ZWIFT_CLIENT_ID
ENV ZWIFT_CLIENT_SECRET=$ZWIFT_CLIENT_SECRET

RUN pnpm install --frozen-lockfile
RUN pnpm --filter web build

FROM node:20-bookworm-slim AS runner

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1

RUN useradd --uid 1001 --create-home --shell /usr/sbin/nologin nextjs

WORKDIR /app

COPY --from=builder /app/apps/web/.next/standalone /app
COPY --from=builder /app/apps/web/public /app/apps/web/public
COPY --from=builder /app/apps/web/.next/static /app/apps/web/.next/static

USER 1001

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=20s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:3000/api/health').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "apps/web/server.js"]
