    "@storybook/react-native": "^9.1.4",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.1.16",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/pako": "^2.0.4",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "~54.0.10",
    "chokidar-cli": "^3.0.0",
