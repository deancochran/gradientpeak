{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm exec expo start -c --lan",
    "dev:e2e": "EXPO_NO_DOTENV=1 bash ./scripts/load-env.sh .env.e2e pnpm exec expo start -c --localhost --dev-client --port 8081",
    "storybook": "bash ./scripts/storybook.sh expo start -c --lan",
    "storybook:generate": "bash ./scripts/storybook.sh sb-rn-get-stories --config-path ./.rnstorybook",
    "storybook:watch": "bash ./scripts/storybook.sh sb-rn-watcher --config-path ./.rnstorybook",
    "generate:maestro": "pnpm --filter @repo/ui generate:selectors && pnpm --filter @repo/ui generate:ui-preview-manifest && bash ./scripts/run-strip-types.sh ./scripts/generate-maestro-preview-flow.mts",
    "maestro:prepare": "bash ./scripts/prepare-maestro-device.sh",
    "maestro": "bash ./scripts/maestro-local.sh",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "pnpm run android:install",
    "android:dev": "pnpm run android:boot && pnpm run android:install",
    "android:boot": "bash ./scripts/android-emulator.sh boot",
    "android:install": "bash ./scripts/android-emulator.sh install",
    "android:install:force": "bash ./scripts/android-emulator.sh install-force",
    "android:e2e:build": "bash ./scripts/android-emulator.sh build-e2e-apk",
    "android:e2e:apk-path": "bash ./scripts/android-emulator.sh print-e2e-apk-path",
    "android:launch": "bash ./scripts/android-emulator.sh launch",
    "ios": "pnpm exec expo run:ios",
    "web": "pnpm exec expo start --web",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:jest": "jest --config ./jest.config.mjs --runInBand",
    "test:jest:file": "jest --config ./jest.config.mjs --runInBand --",
    "test:jest:watch": "jest --config ./jest.config.mjs --watch",
    "check-types": "tsc --noEmit",
    "watch": "bash ./scripts/watch.sh",
    "pretest:e2e": "pnpm run generate:maestro",
    "test:e2e": "pnpm run maestro:prepare && pnpm run maestro -- .maestro/flows/main/tabs_smoke.yaml",
    "pretest:e2e:flow": "pnpm run generate:maestro",
    "test:e2e:flow": "pnpm run maestro:prepare && bash ./scripts/maestro-local.sh",
    "maestro:flow": "pnpm run maestro:prepare && bash ./scripts/maestro-local.sh",
    "maestro:lane": "node ./scripts/run-maestro-lane.mjs",
    "test:e2e:lane": "pnpm run generate:maestro && node ./scripts/run-maestro-lane.mjs",
    "test:e2e:clean": "bash ./scripts/run-strip-types.sh ./scripts/clean-maestro-artifacts.mts",
    "android:gui": "pnpm exec expo run:android"
  },
  "dependencies": {
