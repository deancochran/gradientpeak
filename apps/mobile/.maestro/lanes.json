      ".maestro/flows/journeys/training-plans/shared_duplicate_schedule_plan_sync.yaml",
      ".maestro/flows/main/plan_projection_settings.yaml"
    ]
  },
  "resilience": {
    "description": "Interaction resilience probes and repeated input handling",
    "targets": [
      ".maestro/flows/journeys/resilience/sign_in_invalid_spam_guard.yaml",
      ".maestro/flows/journeys/resilience/warm_relaunch_authenticated.yaml"
    ]
  },
  "perf-sentinel": {
    "description": "Timeout-based readiness checks for user-perceived responsiveness",
    "targets": [
      ".maestro/flows/journeys/resilience/warm_relaunch_authenticated.yaml",
      ".maestro/flows/main/auth_navigation.yaml"
    ]
  }
