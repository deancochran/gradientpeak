STANDARD_USER_EMAIL=test@example.com
STANDARD_USER_PASS=password123
ONBOARDING_USER_EMAIL=onboarding@example.com
ONBOARDING_USER_PASS=password123

# Optional: set this only when you intentionally want to reuse the same sign-up account.
# Leave it unset to let the repo Maestro scripts generate a unique address per sign-up flow.
# SIGNUP_EMAIL=gradientpeak.maestro+manual@example.com
SIGNUP_PASSWORD=Password123

# Optional unique-email generator overrides for repo Maestro scripts.
MAESTRO_SIGNUP_EMAIL_PREFIX=gradientpeak.maestro
MAESTRO_SIGNUP_EMAIL_DOMAIN=example.com

TARGET_USERNAME=coachcasey
TARGET_USER_ID=coachcasey
SHARED_TRAINING_PLAN_NAME=10K Builder
SHARED_ACTIVITY_PLAN_NAME=Tempo Builder
SHARED_ROUTE_NAME=River Loop
PLANNED_ACTIVITY_NAME=Tempo Builder
REQUIRED_METRICS_PLAN_NAME=ERG Builder
SCHEDULED_EVENT_TITLE=Long Run
ACTIVITY_COMMENT_TEXT=Great session from Maestro
HISTORICAL_ACTIVITY_NAME=Imported Tempo Session
PLAN_ANCHOR_DATE=2026-03-30

# Optional social actor accounts for messaging / notification / multiactor scenarios.
DM_SENDER_EMAIL=sender@example.com
DM_SENDER_PASS=password123
DM_RECEIVER_EMAIL=receiver@example.com
DM_RECEIVER_PASS=password123
# Example overlay pattern:
# ACTOR_A_STANDARD_USER_EMAIL=$DM_SENDER_EMAIL
# ACTOR_B_STANDARD_USER_EMAIL=$DM_RECEIVER_EMAIL
# Copy this file to `.maestro/fixtures.env` for local runs.
