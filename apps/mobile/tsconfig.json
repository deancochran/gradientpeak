{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/core": ["../../packages/core/index.ts"],
      "@repo/api": ["../../packages/api/index.ts"],
      "@repo/api/*": ["../../packages/api/src/*"],
      "@repo/auth": ["../../packages/auth/index.ts"],
      "@repo/auth/*": ["../../packages/auth/src/*"],
      "@repo/db": ["../../packages/db/index.ts"]
    }
  },

  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"]
}
