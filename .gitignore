# ------------------------------
# Root Monorepo Gitignore
# Covers apps/ (Next.js + Expo) and packages/ ( Supabase)
# ------------------------------

# Dependencies
node_modules/
.pnp
.pnp.js
*.node

# Local env files
.env*


# Testing
coverage/
*.lcov
coverage/**/*
**/test-results/
**/playwright-report/
**/blob-report/

# Turbo
.turbo/
.tmp/

# Vercel
.vercel/

# ------------------------------
# Next.js (apps/nextjs-app)
# ------------------------------
.next/
out/
**/storybook-static/

# ------------------------------
# Expo / React Native (apps/expo-app)
# ------------------------------
.expo/
.expo-shared/
*.iml
*.apk
*.aar
*.jks
web-build/

.expo/
.expo-shared/
ios/
android/

# Metro bundler cache
.metro-cache/
*.packager

# ------------------------------
# Shared Packages (packages/)
# ------------------------------


# Supabase generated stuff
supabase/.temp/
supabase/.branches/
packages/supabase/.temp/
packages/supabase/.branches/

# Worktree artifacts
.worktrees/
# ------------------------------
# Logs & Debug
# ------------------------------
logs/
.logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
**/.maestro/*.log
**/.maestro/artifacts/
**/.maestro/cache/
**/.maestro/home/
**/.maestro/utils/
**/.maestro/actors/*.env
packages/*/dist/
packages/*/lib/
# ------------------------------
# Misc
# ------------------------------
.DS_Store
*.pem
*.keystore
*.gradle
*.hprof
*.swp

# IDE/editor
.vscode/
.idea/
*.log
*.tsbuildinfo
.aider*

# OpenCode - ignore temporary/state files but allow config
.opencode/temp/
.opencode/state/
.opencode/logs/

# Claude Code
.claude/

# Allow these to be tracked (valuable project assets):
# OpenCode:
# - .opencode/agents/ (agent definitions)
# - .opencode/skills/ (reusable skills)
# - .opencode/commands/ (custom commands)
# - opencode.json (agent config)
# - CLAUDE.md (project documentation)
