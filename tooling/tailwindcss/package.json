{
  "name": "@repo/tailwindcss",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./web.css": "./src/web.css",
    "./native.css": "./src/native.css",
    "./tokens.css": "./src/tokens.css",
    "./native": "./src/native.ts",
    "./theme": "./src/native.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "sync:shadcn-theme": "node ./scripts/sync-shadcn-theme.mjs",
    "generate:theme": "node ./scripts/generate-theme.mjs",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "nativewind": "5.0.0-preview.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "lightningcss": "1.30.1",
    "typescript": "^5"
  }
}
