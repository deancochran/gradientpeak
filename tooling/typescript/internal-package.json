{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "target": "ESNext",
    "verbatimModuleSyntax": true
  }
}
