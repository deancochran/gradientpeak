{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./validation": {
      "types": "./src/validation/index.ts",
      "default": "./src/validation/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "db:start": "tsx scripts/local-db-command.ts start",
    "db:stop": "tsx scripts/local-db-command.ts stop",
    "db:status": "tsx scripts/local-db-command.ts status",
    "db:update": "tsx scripts/local-db-command.ts migration up --local",
    "db:downgrade": "tsx scripts/local-db-command.ts migration down --local",
    "db:reset": "tsx scripts/local-db-command.ts db reset --local",
    "db:migration:new": "tsx scripts/drizzle-generate.ts",
    "db:migration:list": "tsx scripts/local-db-command.ts migration list --local",
    "db:migration:up": "tsx scripts/local-db-command.ts migration up --local",
    "db:migration:down": "tsx scripts/local-db-command.ts migration down --local",
    "db:diff": "tsx scripts/local-db-command.ts db diff --local --schema public",
    "db:lint": "tsx scripts/local-db-command.ts db lint --local --schema public",
    "db:drizzle:pull": "tsx scripts/with-local-db-url.ts drizzle-kit pull --config drizzle.config.ts",
    "db:drizzle:studio": "tsx scripts/with-local-db-url.ts drizzle-kit studio --config drizzle.config.ts",
    "db:migrate": "tsx scripts/with-local-db-url.ts drizzle-kit migrate --config drizzle.config.ts",
    "self-host:up": "tsx scripts/local-db-command.ts start",
    "self-host:down": "tsx scripts/local-db-command.ts stop",
    "functions:serve": "tsx scripts/local-db-command.ts functions serve",
    "functions:deploy": "tsx scripts/local-db-command.ts functions deploy",
    "functions:new": "tsx scripts/local-db-command.ts functions new",
    "seed-templates": "tsx scripts/seed-templates.ts",
    "seed-training-plans": "tsx scripts/seed-training-plan-templates.ts",
    "push": "pnpm drizzle-kit push",
    "studio": "pnpm drizzle-kit studio"
  },
  "dependencies": {
    "@repo/core": "workspace:*",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "supabase": "^2.84.1",
    "tsx": "^4.20.6",
    "typescript": "^5.5.2"
  }
}
