  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "check-types": "tsc --noEmit",
    "watch": "pnpm exec concurrently \"tsc --noEmit --watch --preserveWatchOutput\" \"pnpm exec chokidar '**/*.{ts,tsx,js,jsx,json}' -c 'biome lint .'\""
  },
  "dependencies": {
    "@garmin/fitsdk": "^21.188.0",
