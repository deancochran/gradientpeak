  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/mapbox__polyline": "^1.0.5",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.5.2",
    "vitest": "^4.0.18"
  }
