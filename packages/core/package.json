{
  "name": "@repo/core",
  "version": "1.0.0",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./bluetooth": "./bluetooth/index.ts",
    "./bluetooth/*": "./bluetooth/*.ts",
    "./calculations": "./calculations/index.ts",
    "./constants": "./constants/index.ts",
    "./constants/*": "./constants/*.ts",
    "./duration": "./duration/index.ts",
    "./duration/*": "./duration/*.ts",
    "./estimators": "./estimators/index.ts",
    "./estimators/*": "./estimators/*.ts",
    "./load": "./load/index.ts",
    "./load/*": "./load/*.ts",
    "./sports": "./sports/index.ts",
    "./sports/*": "./sports/*.ts",
    "./zones": "./zones/index.ts",
    "./zones/*": "./zones/*.ts",
    "./estimation": "./estimation/index.ts",
    "./plan": "./plan/index.ts",
    "./schemas/*": "./schemas/*.ts",
    "./utils": "./utils/index.ts",
    "./utils/*": "./utils/*.ts",
    "./ftms-types": "./ftms-types.ts"
  },
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "check-types": "tsc --noEmit",
    "watch": "concurrently \"tsc --noEmit --watch --preserveWatchOutput\" \"chokidar '**/*.{ts,tsx,js,jsx,json}' -c 'biome lint .'\""
  },
  "dependencies": {
    "@garmin/fitsdk": "^21.188.0",
    "@mapbox/polyline": "^1.2.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@repo/supabase": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/mapbox__polyline": "^1.0.5",
    "concurrently": "^9.2.1",
    "typescript": "^5.5.2",
    "vitest": "^4.0.18"
  }
}
