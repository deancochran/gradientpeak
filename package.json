{
  "name": "gradientpeak",
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@playwright/test": "^1.58.2",
    "chokidar-cli": "^3.0.0",
    "lightningcss": "1.30.1",
    "turbo": "^2.6.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "biome check .",
    "dev": "turbo run dev --parallel --ui tui",
    "dev:clean": "bash ./scripts/dev-clean.sh",
    "dev:e2e": "turbo run dev:e2e --parallel --ui tui",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:e2e:web": "pnpm --filter web dev:e2e",
    "dev:e2e:mobile": "pnpm --filter mobile dev:e2e",
    "dev:apps": "turbo run dev --ui tui",
    "watch": "turbo run watch",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "bash ./scripts/test-e2e.sh",
    "test:e2e:web": "pnpm --filter web test:e2e",
    "test:e2e:mobile": "pnpm --filter mobile test:e2e",
    "self-host": "pnpm run self-host:up",
    "self-host:up": "pnpm --filter @repo/supabase dev:supabase",
    "self-host:down": "pnpm --filter @repo/supabase stop:supabase",
    "self-host:stop": "pnpm run self-host:down"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1",
      "zod": "^4.2.1"
    }
  },
  "version": "1.0.0"
}
