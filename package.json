{
  "name": "gradientpeak",
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@playwright/test": "^1.58.2",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "kill-port-cli": "^1.0.2",
    "lightningcss": "1.30.1",
    "turbo": "^2.6.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check": "biome check .",
    "dev": "turbo run dev",
    "dev:logged": "mkdir -p .logs && concurrently --names web,mobile --prefix '[{time} {name}]' --timestamp-format HH:mm:ss --prefix-colors cyan,magenta \"pnpm --filter web dev 2>&1 | tee -a .logs/web-dev.log\" \"pnpm --filter mobile dev 2>&1 | tee -a .logs/mobile-dev.log\" | tee -a .logs/dev.log",
    "dev:clean": "pnpm exec k 3000 3100 8081 8082 || true && pnpm run self-host:down >/dev/null 2>&1 || true && printf '[dev-clean] local web/mobile dev servers and Supabase stopped\n'",
    "dev:e2e": "turbo run dev:e2e --parallel --ui tui",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:e2e:web": "pnpm --filter web dev:e2e",
    "dev:e2e:mobile": "pnpm --filter mobile dev:e2e",
    "watch": "turbo run watch",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "db:start": "pnpm --filter @repo/db db:start",
    "db:stop": "pnpm --filter @repo/db db:stop",
    "db:status": "pnpm --filter @repo/db db:status",
    "db:update": "pnpm --filter @repo/db db:update",
    "db:downgrade": "pnpm --filter @repo/db db:downgrade",
    "db:reset": "pnpm --filter @repo/db db:reset",
    "db:migration:new": "pnpm --filter @repo/db db:migration:new",
    "db:migration:list": "pnpm --filter @repo/db db:migration:list",
    "db:migration:up": "pnpm --filter @repo/db db:migration:up",
    "db:migration:down": "pnpm --filter @repo/db db:migration:down",
    "db:diff": "pnpm --filter @repo/db db:diff",
    "db:lint": "pnpm --filter @repo/db db:lint",
    "db:drizzle:pull": "pnpm --filter @repo/db db:drizzle:pull",
    "db:drizzle:studio": "pnpm --filter @repo/db db:drizzle:studio",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "bash ./scripts/test-e2e.sh",
    "test:e2e:web": "pnpm --filter web test:e2e",
    "test:e2e:mobile": "pnpm --filter mobile test:e2e",
    "self-host:up": "pnpm --filter @repo/db self-host:up",
    "self-host:down": "pnpm --filter @repo/db self-host:down"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "pnpm": {
    "overrides": {
      "baseline-browser-mapping": "2.10.14",
      "browserslist": "4.28.2",
      "caniuse-lite": "1.0.30001784",
      "lightningcss": "1.30.1",
      "@tanstack/react-router>zod": "^3.25.0",
      "@tanstack/router-generator>zod": "^3.25.0",
      "@tanstack/router-plugin>zod": "^3.25.0",
      "@tanstack/start-plugin-core>zod": "^3.25.0",
      "zod": "^4.2.1"
    }
  },
  "version": "1.0.0"
}
